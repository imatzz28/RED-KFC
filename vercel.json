{
    "name": "red-kfc",
    "headers": [
        {
            "source": "/:path*",
            "headers": [
                {
                    "key": "Content-Security-Policy",
                    "value": "frame-ancestors *"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/:path*",
            "destination": "/"
        }
    ]
}